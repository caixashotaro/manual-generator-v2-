# Streamlit Cloud用のシークレット設定例
# このファイルをコピーして secrets.toml として保存するか、
# Streamlit Cloud のダッシュボード（App settings → Secrets）に貼り付けてください

# Groq API Key (https://console.groq.com/ で無料取得)
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxx"

# Anthropic API Key (https://console.anthropic.com/ で取得)
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxx"

# 共有用パスワード（このアプリにアクセスする全員に共通）
APP_PASSWORD = "set-a-strong-password-here"

# Supabase (任意。設定するとプロジェクトがクラウドに保存される)
# Project Settings > API から取得
# SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
# SUPABASE_KEY = "eyJxxxxxxxxxxxxxxxxxxxx"
